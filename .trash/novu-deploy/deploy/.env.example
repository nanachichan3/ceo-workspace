# Copy to .env and fill in values for production
# For Coolify, set these as environment variables in the app settings

# ===== SECRETS (generate with: openssl rand -hex 32) =====
JWT_SECRET=
STORE_ENCRYPTION_KEY=  # Must be exactly 32 chars: openssl rand -hex 16
NOVU_SECRET_KEY=
MONGO_PASSWORD=

# ===== HOST =====
HOST_NAME=http://localhost

# ===== General =====
# available values: 'dev', 'test', 'production', 'ci', 'local'
NODE_ENV=production

# ===== MongoDB =====
MONGO_INITDB_ROOT_USERNAME=root
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=10
# MONGO_URL is constructed as: mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_PASSWORD}@mongodb:27017/novu-db?authSource=admin
MONGO_AUTO_CREATE_INDEXES=true

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_SERVICE_HOST=redis
REDIS_CACHE_SERVICE_PORT=6379

# ===== AWS/S3 =====
S3_LOCAL_STACK=false
S3_BUCKET_NAME=novu-db
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===== Ports =====
API_PORT=3000
WORKER_PORT=3004
WS_PORT=3002

# ===== URLs (set to your domain in Coolify) =====
# API_ROOT_URL: used by API for internal links and callbacks
API_ROOT_URL=https://api.novu.qed.quest
# FRONT_BASE_URL: dashboard URL
FRONT_BASE_URL=https://novu.qed.quest
# VITE_*: used by dashboard container for browser-side API calls
VITE_API_HOSTNAME=https://api.novu.qed.quest
VITE_WEBSOCKET_HOSTNAME=https://ws.novu.qed.quest

# ===== Context paths (leave empty for root部署) =====
API_CONTEXT_PATH=
WS_CONTEXT_PATH=

# ===== Feature flags =====
IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
IS_V2_ENABLED=true
IS_SELF_HOSTED=true
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false

# ===== JWT =====
SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d

# ===== Observability =====
SENTRY_DSN=
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=novu
NEW_RELIC_LICENSE_KEY=

# ===== Queue tuning =====
BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100
